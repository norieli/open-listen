{
  "name": "open-listen-ai",
  "version": "1.0.0",
  "description": "Open Listen AI - 听力阅读学习APP",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:android": "electron-builder --android"
  },
  "author": "Atom",
  "license": "MIT",
  "dependencies": {
    "sql.js": "^1.10.2",
    "electron-log": "^5.1.1",
    "howler": "^2.2.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue-i18n": "^9.10.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.englishpod.ai",
    "productName": "Open listen AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "android": {
      "target": ["apk"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}